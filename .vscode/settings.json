{
    "json.schemas": [
        {
            "fileMatch": [
                "vsl_ial/eval/distance-*.json"
            ],
            "url": "./vsl_ial/eval/distance_schema.json"
        },
        {
            "fileMatch": [
                "vsl_ial/eval/hue-linearity-*.json"
            ],
            "url": "./vsl_ial/eval/hue_linearity_schema.json"
        },
        {
            "fileMatch": [
                "vsl_ial/optimization/*.json"
            ],
            "url": "./vsl_ial/optimization/schema.json"
        }
    ],
    "cSpell.words": [
        "CIELAB",
        "combvd",
        "hstack",
        "linalg",
        "Munsell",
        "newaxis",
        "Oklab",
        "tensordot",
        "whitepoints",
        "xiao"
    ]
}